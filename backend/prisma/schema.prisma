datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  password            String
  name                String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  memberships         GroupMember[]
  createdGroups       Group[]
  paidExpenses        Expense[]
  expenseSplits       ExpenseSplit[]
  settlementsSent     Settlement[]     @relation("PayFrom")
  settlementsReceived Settlement[]     @relation("PayTo")
  importJobs          ImportJob[]
}

model Group {
  id          String        @id @default(uuid())
  name        String
  description String?
  createdById String
  createdBy   User          @relation(fields: [createdById], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
}

model GroupMember {
  id        String    @id @default(uuid())
  groupId   String
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinDate  DateTime  @default(now())
  leaveDate DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([groupId, userId])
}

model Expense {
  id          String         @id @default(uuid())
  description String
  amount      Float
  date        DateTime
  groupId     String
  group       Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidById    String
  paidBy      User           @relation(fields: [paidById], references: [id])
  splitType   String         // EQUAL, EXACT, PERCENTAGE
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  splits      ExpenseSplit[]
}

model ExpenseSplit {
  id         String   @id @default(uuid())
  expenseId  String
  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount     Float    // Share amount
  percentage Float?   // Share percentage if applicable
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([expenseId, userId])
}

model Settlement {
  id         String   @id @default(uuid())
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payFromId  String
  payFrom    User     @relation("PayFrom", fields: [payFromId], references: [id], onDelete: Cascade)
  payToId    String
  payTo      User     @relation("PayTo", fields: [payToId], references: [id], onDelete: Cascade)
  amount     Float
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ImportJob {
  id          String          @id @default(uuid())
  fileName    String
  status      String          @default("PENDING_APPROVAL") // PENDING_APPROVAL, COMPLETED, FAILED
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  completedAt DateTime?
  rawData     String?         // Holds JSON text of the parsed CSV rows during review
  anomalies   ImportAnomaly[]
}

model ImportAnomaly {
  id          String    @id @default(uuid())
  importJobId String
  importJob   ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  rowNumber   Int
  severity    String    // WARNING, ERROR
  type        String    // DUPLICATE, NEGATIVE_AMOUNT, CURRENCY_MISMATCH, MISSING_PAYER, SETTLEMENT_LOGGED_AS_EXPENSE, INVALID_DATE, FUTURE_DATE, INACTIVE_MEMBER, SPLIT_MISMATCH, UNKNOWN_MEMBER, MISSING_REQUIRED_FIELD
  message     String
  rawData     String    // JSON string of row
  resolution  String    @default("PENDING") // APPROVED, SKIPPED, CORRECTED, BLOCKED, PENDING
  createdAt   DateTime  @default(now())
}
